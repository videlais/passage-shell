{
  "name": "passage-shell",
  "version": "2.0.0",
  "description": "CLI tool for automated testing of HTML-based interactive fiction projects.",
  "type": "module",
  "main": "src/runner.js",
  "bin": {
    "passage-shell": "./cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "start:web": "node src/web/server.js",
    "dev:web": "vite",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint ./src --fix",
    "all": "npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/videlais/passage-shell.git"
  },
  "keywords": [
    "interactive-fiction",
    "testing",
    "cli",
    "playwright"
  ],
  "author": "Dan Cox",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "electron": "^42.3.3",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
